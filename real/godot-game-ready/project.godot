; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Tutorial Components & Scripts"
config/description="Godot tutorial components and game scripts from RapidVectors"
config/version="1.0"
run/main_scene="res://croptails_scripts/scenes/characters/npc_states/main.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[debug]

gdscript/warnings/return_value_discarded=1
gdscript/warnings/unused_argument=1

[physics]

2d/default_gravity=980
